<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<template id="report_household_invoice_document">
    <t t-call="web.html_container">
        <t t-set="o_config" t-value="env['household.store.config'].sudo().search([], limit=1)"/>
        <t t-foreach="docs" t-as="o">
            <t t-set="inv_date"  t-value="o.invoice_date or o.date"/>
            <t t-set="inv_day"   t-value="inv_date.day   if inv_date else ''"/>
            <t t-set="inv_month" t-value="inv_date.month if inv_date else ''"/>
            <t t-set="inv_year"  t-value="inv_date.year  if inv_date else ''"/>

            <main>
                <!-- div.article: Odoo wrap qua minimal_layout, thêm charset utf-8 cho wkhtmltopdf -->
                <div class="article" style="font-family: 'Noto Sans', 'DejaVu Sans', sans-serif; font-size: 11pt; color: #222; padding: 20px 28px; box-sizing: border-box;">

                    <!-- ===== HEADER CỬA HÀNG ===== -->
                    <div style="text-align: center; margin-bottom: 8px;">
                        <div style="font-size: 15pt; font-weight: bold; text-transform: uppercase; letter-spacing: 1px;">
                            <t t-esc="o_config.store_name if o_config else 'CỬA HÀNG'"/>
                        </div>
                        <t t-if="o_config and o_config.specialty">
                            <div style="font-size: 10pt; margin-top: 2px;">Chuyên: <t t-esc="o_config.specialty"/></div>
                        </t>
                        <t t-if="o_config and o_config.address">
                            <div style="font-size: 10pt;">Đ/C: <t t-esc="o_config.address"/></div>
                        </t>
                        <t t-if="o_config and o_config.phone">
                            <div style="font-size: 10pt;">SĐT: <t t-esc="o_config.phone"/></div>
                        </t>
                        <t t-if="o_config and (o_config.bank_account or o_config.bank_name or o_config.bank_owner)">
                            <div style="font-size: 10pt;">
                                STK:
                                <t t-if="o_config.bank_account"><t t-esc="o_config.bank_account"/></t>
                                <t t-if="o_config.bank_name"> - <t t-esc="o_config.bank_name"/></t>
                                <t t-if="o_config.bank_owner"> - <t t-esc="o_config.bank_owner"/></t>
                            </div>
                        </t>
                    </div>

                    <hr style="border: none; border-top: 1.5px solid #333; margin: 6px 0;"/>

                    <!-- ===== TIÊU ĐỀ ===== -->
                    <div style="text-align: center; margin: 10px 0 6px 0;">
                        <div style="font-size: 15pt; font-weight: bold; text-transform: uppercase; letter-spacing: 2px;">
                            HÓA ĐƠN BÁN HÀNG
                        </div>
                        <div style="font-size: 10pt; margin-top: 4px;">
                            Số hóa đơn: <strong><t t-esc="o.name"/></strong>
                            <t t-if="inv_date">
                                &#160;&#160;&#160;
                                Ngày <t t-esc="inv_day"/> tháng <t t-esc="inv_month"/> năm <t t-esc="inv_year"/>
                            </t>
                        </div>
                    </div>

                    <!-- ===== THÔNG TIN KHÁCH HÀNG ===== -->
                    <div style="margin: 10px 0 6px 0; font-size: 10.5pt; line-height: 1.7;">
                        <div>
                            Khách hàng:
                            <strong><t t-esc="o.customer_name or (o.partner_id.name if o.partner_id else '')"/></strong>
                            <span style="display: inline-block; width: 60px;"/>
                            SĐT: .............................
                        </div>
                        <div>
                            Địa chỉ:
                            <t t-if="o.partner_id and o.partner_id.street">
                                <t t-esc="o.partner_id.street"/>
                            </t>
                            <t t-else="">.............................................................................................</t>
                        </div>
                        <div>
                            Diễn Giải:
                            <t t-if="o.narration"><t t-esc="o.narration"/></t>
                            <t t-else="">.............................................................................................</t>
                        </div>
                    </div>

                    <!-- ===== BẢNG SẢN PHẨM ===== -->
                    <table style="width: 100%; border-collapse: collapse; font-size: 9.5pt; margin-top: 6px;">
                        <thead>
                            <tr style="background-color: #e0e0e0;">
                                <th style="border: 1px solid #999; padding: 4px 5px; text-align: center; width: 4%;">STT</th>
                                <th style="border: 1px solid #999; padding: 4px 5px; text-align: left;   width: 30%;">Tên Hàng</th>
                                <th style="border: 1px solid #999; padding: 4px 5px; text-align: center; width: 7%;">ĐVT</th>
                                <th style="border: 1px solid #999; padding: 4px 5px; text-align: center; width: 6%;">SL</th>
                                <th style="border: 1px solid #999; padding: 4px 5px; text-align: right;  width: 14%;">Đơn Giá</th>
                                <th style="border: 1px solid #999; padding: 4px 5px; text-align: center; width: 7%;">CK%</th>
                                <th style="border: 1px solid #999; padding: 4px 5px; text-align: right;  width: 14%;">Giá sau CK</th>
                                <th style="border: 1px solid #999; padding: 4px 5px; text-align: right;  width: 14%;">Thành Tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="stt" t-value="0"/>
                            <t t-foreach="o.invoice_line_ids.filtered(lambda l: l.display_type == 'product')" t-as="line">
                                <t t-set="stt" t-value="stt + 1"/>
                                <t t-set="price_after_ck" t-value="line.price_unit * (1.0 - (line.discount or 0.0) / 100.0)"/>
                                <tr t-att-style="'background-color: ' + ('#f7f7f7' if stt % 2 == 0 else '#fff') + ';'">
                                    <td style="border: 1px solid #bbb; padding: 3px 5px; text-align: center;"><t t-esc="stt"/></td>
                                    <td style="border: 1px solid #bbb; padding: 3px 5px;">
                                        <t t-esc="line.product_id.name if line.product_id else line.name"/>
                                    </td>
                                    <td style="border: 1px solid #bbb; padding: 3px 5px; text-align: center;">
                                        <t t-esc="line.product_uom_id.name if line.product_uom_id else ''"/>
                                    </td>
                                    <td style="border: 1px solid #bbb; padding: 3px 5px; text-align: center;">
                                        <t t-esc="'{:,.0f}'.format(line.quantity).replace(',', '.')"/>
                                    </td>
                                    <td style="border: 1px solid #bbb; padding: 3px 5px; text-align: right;">
                                        <t t-esc="'{:,.0f}'.format(line.price_unit).replace(',', '.')"/>
                                    </td>
                                    <td style="border: 1px solid #bbb; padding: 3px 5px; text-align: center;">
                                        <t t-esc="'{:.0f}'.format(line.discount or 0)"/>
                                    </td>
                                    <td style="border: 1px solid #bbb; padding: 3px 5px; text-align: right;">
                                        <t t-esc="'{:,.0f}'.format(price_after_ck).replace(',', '.')"/>
                                    </td>
                                    <td style="border: 1px solid #bbb; padding: 3px 5px; text-align: right; font-weight: bold;">
                                        <t t-esc="'{:,.0f}'.format(line.price_subtotal).replace(',', '.')"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- ===== TỔNG TIỀN ===== -->
                    <div style="margin-top: 8px; text-align: right; font-size: 10pt; line-height: 1.9;">
                        <span>Tiền hàng:</span>
                        <span style="display: inline-block; min-width: 130px; text-align: right;">
                            <t t-esc="'{:,.0f}'.format(o.amount_untaxed).replace(',', '.')"/> ₫
                        </span>
                        <br/>
                        <t t-if="o.amount_tax and o.amount_tax > 0">
                            <span>Thuế VAT:</span>
                            <span style="display: inline-block; min-width: 130px; text-align: right;">
                                <t t-esc="'{:,.0f}'.format(o.amount_tax).replace(',', '.')"/> ₫
                            </span>
                            <br/>
                        </t>
                        <strong>
                            <span>Tổng cộng:</span>
                            <span style="display: inline-block; min-width: 130px; text-align: right; font-size: 12pt;">
                                <t t-esc="'{:,.0f}'.format(o.amount_total).replace(',', '.')"/> ₫
                            </span>
                        </strong>
                    </div>

                    <!-- ===== SỐ TIỀN BẰNG CHỮ ===== -->
                    <div style="margin-top: 8px; font-size: 10pt; font-style: italic;">
                        Số tiền viết bằng chữ: <strong><t t-esc="o._amount_to_words()"/></strong>
                    </div>

                    <!-- ===== NGÀY XUẤT ===== -->
                    <div style="margin-top: 4px; font-size: 10pt;">
                        <t t-if="inv_date">
                            Xuất ngày: Ngày <t t-esc="inv_day"/> tháng <t t-esc="inv_month"/> năm <t t-esc="inv_year"/>
                        </t>
                    </div>

                    <!-- ===== KÝ TÊN ===== -->
                    <table style="width: 100%; border-collapse: collapse; margin-top: 20px; font-size: 10pt; text-align: center;">
                        <tr>
                            <td style="width: 20%; padding: 0 4px; vertical-align: top;">
                                <div style="font-weight: bold;">Người bán hàng</div>
                                <div style="font-size: 8.5pt; color: #666; margin-top: 2px;">(Ký và ghi rõ họ tên)</div>
                                <div style="height: 65px;"/>
                            </td>
                            <td style="width: 20%; padding: 0 4px; vertical-align: top;">
                                <div style="font-weight: bold;">Thủ kho</div>
                                <div style="font-size: 8.5pt; color: #666; margin-top: 2px;">(Ký và ghi rõ họ tên)</div>
                                <div style="height: 65px;"/>
                            </td>
                            <td style="width: 20%; padding: 0 4px; vertical-align: top;">
                                <div style="font-weight: bold;">Người mua hàng</div>
                                <div style="font-size: 8.5pt; color: #666; margin-top: 2px;">(Ký và ghi rõ họ tên)</div>
                                <div style="height: 65px;"/>
                            </td>
                            <td style="width: 20%; padding: 0 4px; vertical-align: top;">
                                <div style="font-weight: bold;">Kế toán</div>
                                <div style="font-size: 8.5pt; color: #666; margin-top: 2px;">(Ký và ghi rõ họ tên)</div>
                                <div style="height: 65px;"/>
                            </td>
                            <td style="width: 20%; padding: 0 4px; vertical-align: top;">
                                <div style="font-weight: bold;">Mã QR thanh toán</div>
                                <t t-if="o_config and o_config.qr_image">
                                    <div style="margin-top: 4px;">
                                        <img t-att-src="image_data_uri(o_config.qr_image)"
                                             style="width: 90px; height: 90px; object-fit: contain;"
                                             alt="QR"/>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div style="width: 90px; height: 90px; border: 1px dashed #aaa; margin: 4px auto; font-size: 8pt; color: #aaa; line-height: 90px;">QR</div>
                                </t>
                            </td>
                        </tr>
                    </table>

                </div><!-- end .article -->
            </main>
        </t>
    </t>
</template>

</data>
</odoo>
