<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

    <!-- Form View -->
    <record id="view_household_store_config_form" model="ir.ui.view">
        <field name="name">household.store.config.form</field>
        <field name="model">household.store.config</field>
        <field name="arch" type="xml">
            <form string="Thông tin cửa hàng">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="store_name" placeholder="Tên cửa hàng..."/>
                        </h1>
                    </div>
                    <group string="Thông tin cửa hàng">
                        <group>
                            <field name="store_name"/>
                            <field name="specialty"/>
                            <field name="address"/>
                            <field name="phone"/>
                        </group>
                    </group>
                    <group string="Thông tin ngân hàng">
                        <group>
                            <field name="bank_account"/>
                            <field name="bank_name"/>
                            <field name="bank_owner"/>
                        </group>
                    </group>
                    <group string="Mã QR thanh toán">
                        <field name="qr_image" widget="image" options="{'size': [200, 200]}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_household_store_config_tree" model="ir.ui.view">
        <field name="name">household.store.config.tree</field>
        <field name="model">household.store.config</field>
        <field name="arch" type="xml">
            <list string="Thông tin cửa hàng">
                <field name="store_name"/>
                <field name="specialty"/>
                <field name="address"/>
                <field name="phone"/>
                <field name="bank_account"/>
                <field name="bank_name"/>
                <field name="bank_owner"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_household_store_config" model="ir.actions.act_window">
        <field name="name">Thông tin cửa hàng</field>
        <field name="res_model">household.store.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Chưa có thông tin cửa hàng. Tạo mới ngay!
            </p>
        </field>
    </record>

    <!-- Top-level menu -->
    <menuitem id="menu_household_top"
              name="Tuyen Hoa Store"
              sequence="200"/>

    <!-- Config submenu -->
    <menuitem id="menu_household_config"
              name="Cấu hình"
              parent="menu_household_top"
              sequence="10"/>

    <!-- Store config menu item -->
    <menuitem id="menu_household_store_config"
              name="Thông tin cửa hàng"
              parent="menu_household_config"
              action="action_household_store_config"
              sequence="10"/>

</data>
</odoo>
