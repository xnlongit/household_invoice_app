<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ================================================================
     Trang tổng quan (Dashboard)
================================================================ -->
<template id="page_dashboard" name="Trang tổng quan">
    <html class="light" lang="vi">
    <head>
        <meta charset="utf-8"/>
        <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
        <title>Tổng quan | Tuyển Hoa Store</title>
        <t t-call="household_invoice_app.assets_common"/>
    </head>
    <body class="bg-background text-on-background min-h-screen">
        <t t-call="household_invoice_app.topnav"/>

        <main class="max-w-7xl mx-auto px-8 py-12">
            <!-- Tiêu đề chính -->
            <section class="mb-12">
                <h1 class="text-5xl font-extrabold font-headline tracking-tight text-on-surface mb-2">
                    Xin chào, <t t-esc="user_name or 'Người dùng'"/>.
                </h1>
                <p class="text-lg text-on-surface-variant max-w-2xl">
                    Đây là tổng quan tài chính cửa hàng của bạn.
                </p>
            </section>

            <!-- Thống kê nhanh -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
                <div class="bg-surface-container-low p-6 rounded-lg">
                    <p class="text-sm text-on-surface-variant mb-1 font-medium">Tổng doanh thu</p>
                    <p class="text-3xl font-extrabold font-headline text-on-surface" id="stat-revenue">—</p>
                </div>
                <div class="bg-surface-container-low p-6 rounded-lg">
                    <p class="text-sm text-on-surface-variant mb-1 font-medium">Chưa thanh toán</p>
                    <p class="text-3xl font-extrabold font-headline text-on-surface" id="stat-outstanding">—</p>
                </div>
                <div class="bg-surface-container-low p-6 rounded-lg">
                    <p class="text-sm text-on-surface-variant mb-1 font-medium">Khách hàng</p>
                    <p class="text-3xl font-extrabold font-headline text-on-surface" id="stat-clients">—</p>
                </div>
                <div class="bg-surface-container-low p-6 rounded-lg">
                    <p class="text-sm text-on-surface-variant mb-1 font-medium">Hóa đơn chờ</p>
                    <p class="text-3xl font-extrabold font-headline text-on-surface" id="stat-pending">—</p>
                </div>
            </div>

            <!-- Lưới bento -->
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 mb-12">
                <!-- Thẻ tạo hóa đơn -->
                <div class="md:col-span-8 group relative overflow-hidden bg-surface-container-lowest rounded-xl p-8 flex flex-col justify-between min-h-80 shadow-sm hover:shadow-md transition-shadow">
                    <div class="relative z-10">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-12 h-12 rounded-lg editorial-gradient flex items-center justify-center text-on-primary-container">
                                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">add_notes</span>
                            </div>
                            <span class="text-sm font-bold uppercase tracking-widest text-primary font-headline">Cần thực hiện</span>
                        </div>
                        <h2 class="text-4xl font-bold font-headline text-on-surface leading-tight mb-4">Tạo hóa đơn</h2>
                        <p class="text-on-surface-variant text-lg max-w-md">
                            Tạo hóa đơn chuyên nghiệp trong vài giây với tính toán thuế tự động.
                        </p>
                    </div>
                    <div class="mt-8 flex gap-4 relative z-10">
                        <a href="/app/invoices/new"
                           class="px-8 py-4 rounded-lg editorial-gradient text-on-primary-container font-bold font-headline flex items-center gap-2 group-hover:scale-105 transition-transform">
                            Tạo hóa đơn mới
                            <span class="material-symbols-outlined">arrow_forward</span>
                        </a>
                        <a href="/app/invoices"
                           class="px-8 py-4 rounded-lg bg-surface-container-high text-primary font-bold font-headline hover:bg-surface-container-highest transition-colors">
                            Xem tất cả hóa đơn
                        </a>
                    </div>
                    <div class="absolute top-0 right-0 w-1/2 h-full opacity-5 pointer-events-none translate-x-12 translate-y-8">
                        <span class="material-symbols-outlined text-[300px]">description</span>
                    </div>
                </div>

                <!-- Thẻ sản phẩm -->
                <div class="md:col-span-4 bg-surface-container-low rounded-xl p-8 flex flex-col shadow-sm">
                    <div class="flex items-center gap-3 mb-4">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings:'FILL' 1">inventory_2</span>
                        <h3 class="text-xl font-bold font-headline">Sản phẩm</h3>
                    </div>
                    <p class="text-on-surface-variant text-sm mb-6 flex-1">
                        Quản lý danh mục sản phẩm và bảng giá để tạo hóa đơn nhanh hơn.
                    </p>
                    <a href="/app/products"
                       class="text-sm font-bold text-primary font-headline flex items-center justify-center gap-2 py-3 border-2 border-dashed border-outline-variant rounded-lg hover:border-primary transition-colors">
                        <span class="material-symbols-outlined text-sm">open_in_new</span>
                        Xem danh sách sản phẩm
                    </a>
                </div>
            </div>

            <!-- Bảng hóa đơn gần đây -->
            <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h3 class="text-2xl font-bold font-headline text-on-surface">Hóa đơn gần đây</h3>
                        <p class="text-on-surface-variant">Hoạt động tài chính gần nhất của bạn.</p>
                    </div>
                    <a href="/app/invoices" class="text-sm font-bold text-primary font-headline hover:underline">
                        Xem tất cả
                    </a>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-surface-container-highest">
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest text-on-surface-variant font-headline rounded-l-lg">Số HĐ</th>
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest text-on-surface-variant font-headline">Khách hàng</th>
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest text-on-surface-variant font-headline">Ngày</th>
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest text-on-surface-variant font-headline">Trạng thái</th>
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-widest text-on-surface-variant font-headline text-right rounded-r-lg">Tổng tiền</th>
                            </tr>
                        </thead>
                        <tbody id="recent-invoices-body">
                            <tr>
                                <td colspan="5" class="px-6 py-10 text-center">
                                    <div class="skeleton h-5 w-full mb-3"></div>
                                    <div class="skeleton h-5 w-4/5 mx-auto mb-3"></div>
                                    <div class="skeleton h-5 w-3/5 mx-auto"></div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>

        <!-- Nút FAB -->
        <div class="fixed bottom-8 right-8 z-40">
            <a href="/app/invoices/new"
               class="w-16 h-16 rounded-full editorial-gradient text-on-primary-container shadow-xl flex items-center justify-center hover:scale-110 transition-transform"
               title="Tạo hóa đơn mới">
                <span class="material-symbols-outlined text-3xl">add</span>
            </a>
        </div>

        <t t-call="household_invoice_app.mobile_nav"/>
        <script type="text/javascript" src="/household_invoice_app/static/src/js/pages/dashboard.js"></script>
    </body>
    </html>
</template>

</data>
</odoo>
